{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    "opener:default",
    "sql:default",
    "sql:allow-load",
    "sql:allow-execute",
    "sql:allow-close",
    "sql:allow-select",
    {
  "identifier": "http:default",
  "allow": [
    "http://localhost:8080/*",
    "http://localhost:8081/*",
    "https://*.tauri.app"
    ]
    }
  ]
}